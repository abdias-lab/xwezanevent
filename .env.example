NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
FEDAPAY_SECRET_KEY=your-fedapay-secret-key
FEDAPAY_PUBLIC_KEY=your-fedapay-public-key
FEDAPAY_ENVIRONMENT=sandbox
# Secret du webhook FedaPay (dashboard → Webhooks) — requis pour confirmer
# les paiements Mobile Money de façon asynchrone et fiable.
FEDAPAY_WEBHOOK_SECRET=your-fedapay-webhook-secret
RESEND_API_KEY=your-resend-api-key
# Expéditeur des emails, domaine vérifié sur Resend (ex. xwezan.com).
RESEND_FROM_EMAIL="XwézanEvent <billets@xwezan.com>"
